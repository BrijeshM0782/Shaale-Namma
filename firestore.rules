rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'brijeshtinku07@gmail.com'
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Daily Meals
    match /dailyMeals/{date} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Facilities
    match /facilities/{facilityId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Students
    match /students/{studentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow create: if true; // Open to everyone as per requirement (No login required for parents)
      allow read, list: if isAdmin();
      allow delete, update: if isAdmin();
    }
    
    // Admin collection for manual bootstrapping if needed
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
